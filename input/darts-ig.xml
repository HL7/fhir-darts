    <!-- copyright year is a mandatory parameter -->
    <parameter>
      <code value="copyrightyear"/>
      <value value="2026+"/>
    </parameter>
    <!-- releaselabel should be the ballot status for HL7-published IGs. -->
    <parameter>
      <code value="releaselabel"/>
     <value value="STU1 Release 1 - Standard for Trial-Use"/>
    </parameter>
    <parameter>
